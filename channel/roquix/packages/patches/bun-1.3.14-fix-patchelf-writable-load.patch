Backport Bun's fix for patchelf-created ELF layouts to the Zig ELF
implementation used by Bun 1.3.14.

Origin: backport, https://github.com/oven-sh/bun/pull/31024
Bug-Upstream: https://github.com/oven-sh/bun/issues/31023
Regression-By: https://github.com/oven-sh/bun/pull/29967

patchelf may add a writable PT_LOAD before Bun's original writable segment
when it relocates dynamic metadata.  Bun 1.3.14 selected the first writable
PT_LOAD and assumed it contained .bun.  Extending patchelf's segment then
overlapped the read-only and executable segments in `bun build --compile`
output.  Select the writable PT_LOAD that actually contains .bun instead.

diff --git a/src/exe_format/elf.zig b/src/exe_format/elf.zig
index b9935c000..6fd5579ce 100644
--- a/src/exe_format/elf.zig
+++ b/src/exe_format/elf.zig
@@ -169,6 +169,7 @@ pub const ElfFile = struct {
         const ehdr = readEhdr(self.data.items);
         const bun_section = try self.findBunSection(ehdr);
         const bun_section_offset = bun_section.file_offset;
+        const bun_section_vaddr = bun_section.vaddr;
         const page_size = pageSize(ehdr);
 
         const header_size: u64 = @sizeOf(u64);
@@ -177,10 +178,17 @@ pub const ElfFile = struct {
         const aligned_new_size = alignUp(new_content_size, page_size);
 
-        // Locate the writable PT_LOAD we'll extend. .bun lives in this
-        // segment already (BlobHeader is `aligned(16K)` + PROGBITS with WA
-        // flags). Growing an existing PT_LOAD is the layout a linker would
-        // naturally produce; WSL1's kernel loader rejects binaries that
-        // instead add a late PT_LOAD by repurposing PT_GNU_STACK (#29963).
+        // Locate the writable PT_LOAD that actually contains .bun.  A Bun
+        // binary post-processed by patchelf can have a second writable
+        // PT_LOAD inserted before Bun's original writable segment (#31023).
+        // Extending that unrelated segment would overlap the read-only and
+        // executable mappings and corrupt `bun build --compile` output.
+        //
+        // Match by vaddr containment so we grow the segment .bun already
+        // lives in (BlobHeader is `aligned(16K)` + PROGBITS with WA flags).
+        // Growing that existing PT_LOAD is the layout a linker would
+        // naturally produce; WSL1's kernel loader rejects binaries that add
+        // a late PT_LOAD by repurposing PT_GNU_STACK (#29963).  This is the
+        // Bun 1.3.14 Zig backport of upstream PR #31024.
         const phdr_size = @sizeOf(Elf64_Phdr);
         var rw_phdr_index: ?usize = null;
         var rw_phdr: Elf64_Phdr = undefined;
@@ -193,7 +201,10 @@ pub const ElfFile = struct {
             const vaddr_end = phdr.p_vaddr + phdr.p_memsz;
             if (vaddr_end > max_vaddr_end) max_vaddr_end = vaddr_end;
 
-            if ((phdr.p_flags & elf.PF_W) != 0 and rw_phdr_index == null) {
+            if ((phdr.p_flags & elf.PF_W) != 0 and
+                phdr.p_vaddr <= bun_section_vaddr and
+                bun_section_vaddr < vaddr_end)
+            {
                 rw_phdr_index = i;
                 rw_phdr = phdr;
             }
@@ -359,5 +370,8 @@ pub const ElfFile = struct {
         /// File offset of the .bun section's data (sh_offset).
         file_offset: u64,
+        /// Virtual address of .bun (sh_addr), used to find its PT_LOAD when
+        /// post-processing has introduced another writable segment.
+        vaddr: u64,
         /// Index of the .bun section in the section header table.
         section_index: u16,
     };
@@ -391,6 +405,7 @@ pub const ElfFile = struct {
                 if (bun.strings.eqlComptime(name, ".bun")) {
                     return .{
                         .file_offset = shdr.sh_offset,
+                        .vaddr = shdr.sh_addr,
                         .section_index = @intCast(i),
                     };
                 }
